MIMC_APP_ID=replace-with-app-id
MIMC_APP_KEY=replace-on-server
MIMC_APP_SECRET=replace-on-server

# Existing PHP login middleware stores the unique backend user id here.
MIMC_SESSION_USER_KEY=user_id

# Development E2E only. Disable these in production.
MIMC_TEST_MODE=false
MIMC_TEST_AUTH_TOKEN=replace-with-a-random-local-secret
MIMC_CORS_ORIGIN=http://localhost:7357

# Optional upstream tuning.
MIMC_TOKEN_UPSTREAM=https://mimc.chat.xiaomi.net/api/account/token
MIMC_TOKEN_TIMEOUT=10
